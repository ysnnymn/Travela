
<!DOCTYPE html>
<html lang="en">
@await Component.InvokeAsync("_AdminLayoutHead")
<body class="inner_page tables_page">
<div class="full_container">
    <div class="inner_container">
      @await Component.InvokeAsync("_AdminLayoutSidebar")
        <!-- right content -->
        <div id="content">
            @await Component.InvokeAsync("_AdminLayoutTopbar")
            <!-- dashboard inner -->
            @RenderBody()
            <!-- end dashboard inner -->
            @await Component.InvokeAsync("_AdminLayoutFooter")
        </div>
  
    </div>
    <!-- model popup -->
    <!-- The Modal -->
    <div class="modal fade" id="myModal">
        <div class="modal-dialog">
            <div class="modal-content">
                <!-- Modal Header -->
                <div class="modal-header">
                    <h4 class="modal-title">Modal Heading</h4>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <!-- Modal body -->
                <div class="modal-body">
                    Modal body..
                </div>
                <!-- Modal footer -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
    <!-- end model popup -->
</div>
@await Component.InvokeAsync("_AdminLayoutScript")
</body>
</html>

