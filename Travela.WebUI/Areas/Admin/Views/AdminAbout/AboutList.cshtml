                                                        data-target="#aboutModal">
                                                    Daha fazlasını gör
                                                </button>
                                            }
                                        </td>

                                        <td>
                                                 width="80"
                                                 height="80"
                                                 style="object-fit:cover;border-radius:8px;" />
                                        </td>

                                    </tr>

                                </tbody>

                            </table>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>
</div>

<div class="modal fade" id="aboutModal" tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header">


                    <span>&times;</span>
                </button>

            </div>

            </div>

        </div>

    </div>

</div>
