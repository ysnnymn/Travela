                    </div>

                    <div class="table_section padding_infor_info">

                        <div class="table-responsive-sm">

                            <table class="table table-dark table-striped">

                                <thead>
                                <tr>
                                    <th>Id</th>
                                    <th>Başlık</th>
                                    <th>Açıklama</th>
                                    <th>Resim</th>
                                </tr>
                                </thead>

                                <tbody>

                                    <tr>



                                        <td>

                                            {
                                                <br />
